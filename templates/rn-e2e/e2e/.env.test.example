TEST_USER_EMAIL=you+e2e@example.com
TEST_USER_PASSWORD=replace-me

NEW_USER_EMAIL=e2e-newuser@e2e.test
NEW_USER_PASSWORD=replace-me-strong
NEW_USER_FULL_NAME=E2E New User
NEW_USER_USERNAME=e2enewuser

IOS_BUNDLE_ID=com.example.app
IOS_DEVICE_NAME=iPhone 15
IOS_PLATFORM_VERSION=17.5
IOS_APP_PATH=

# UDID + Metro port for `npm run e2e:ios:locked` (cross-worktree coordination).
# IOS_UDID pins Appium to a specific simulator (`xcrun simctl list devices`).
# RCT_METRO_PORT must match the port the .app was built against — rebuild via:
#   scripts/metro-lock/with-metro.sh --from-env RCT_METRO_PORT \
#     -- npx expo run:ios --device "<name>"
IOS_UDID=
RCT_METRO_PORT=8081
